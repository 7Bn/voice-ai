# Copy to .env and fill in real values. Never commit .env.

# --- PostgreSQL ---
POSTGRES_PASSWORD=change_me_in_production

# --- App ---
DATABASE_URL=postgresql+asyncpg://voice_ai:change_me_in_production@db:5432/voice_ai
SECRET_KEY=change_me_in_production
ENVIRONMENT=production

# --- Twilio ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_SMS_FROM=+1XXXXXXXXXX

# --- LiveKit ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=xxxx
LIVEKIT_API_SECRET=xxxx

# --- AI providers ---
ANTHROPIC_API_KEY=sk-ant-xxxx
DEEPGRAM_API_KEY=xxxx
ELEVENLABS_API_KEY=xxxx

# --- AWS (S3 — HIPAA-eligible us-east-1 bucket) ---
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1
S3_BUCKET=your-hipaa-bucket-name

# --- Notifications (NotifyAdapter) ---
SENDGRID_API_KEY=SG.xxxx
SENDGRID_FROM_EMAIL=noreply@yourvoiceai.com
